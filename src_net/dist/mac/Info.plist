<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- macOS IMKit 入力メソッド bundle 定義(C++ src/mac の Info.plist 相当)。
     本体ロジックは Mozc.Os.Mac(C#)、ObjC IMKInputController サブクラスは極薄 native。 -->
<plist version="1.0">
<dict>
  <key>CFBundleIdentifier</key>
  <string>org.mozc.inputmethod.Mozc</string>
  <key>CFBundleName</key>
  <string>Mozc</string>
  <key>CFBundleVersion</key>
  <string>1.0.0</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
  <key>LSBackgroundOnly</key>
  <true/>
  <key>InputMethodConnectionName</key>
  <string>org.mozc.inputmethod.Mozc_Connection</string>
  <key>InputMethodServerControllerClass</key>
  <string>MozcImkInputController</string>
  <key>tsInputMethodCharacterRepertoireKey</key>
  <array><string>Hira</string></array>
  <key>ComponentInputModeDict</key>
  <dict>
    <key>tsInputModeListKey</key>
    <array>
      <string>com.apple.inputmethod.Japanese</string>
    </array>
    <key>tsInputModeDefaultKey</key>
    <string>com.apple.inputmethod.Japanese</string>
  </dict>
</dict>
</plist>
