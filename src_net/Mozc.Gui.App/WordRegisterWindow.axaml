<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Mozc.Gui;assembly=Mozc.Gui"
        x:Class="Mozc.Gui.App.WordRegisterWindow"
        x:DataType="vm:WordRegisterViewModel"
        Width="420" Height="240" Title="単語登録"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" ColumnDefinitions="Auto,*">
    <TextBlock Grid.Row="0" Grid.Column="0" Text="読み" VerticalAlignment="Center" Margin="0,4"/>
    <TextBox Grid.Row="0" Grid.Column="1" Margin="8,4" Text="{Binding Reading}"/>

    <TextBlock Grid.Row="1" Grid.Column="0" Text="単語" VerticalAlignment="Center" Margin="0,4"/>
    <TextBox Grid.Row="1" Grid.Column="1" Margin="8,4" Text="{Binding Word}"/>

    <TextBlock Grid.Row="2" Grid.Column="0" Text="品詞" VerticalAlignment="Center" Margin="0,4"/>
    <ComboBox Grid.Row="2" Grid.Column="1" Margin="8,4" HorizontalAlignment="Stretch"
              ItemsSource="{Binding PosList}" SelectedItem="{Binding Pos}"/>

    <TextBlock Grid.Row="3" Grid.Column="0" Text="コメント" VerticalAlignment="Center" Margin="0,4"/>
    <TextBox Grid.Row="3" Grid.Column="1" Margin="8,4" Text="{Binding Comment}"/>

    <Button Grid.Row="5" Grid.Column="1" HorizontalAlignment="Right"
            Content="登録" Command="{Binding RegisterCommand}"/>
  </Grid>
</Window>
